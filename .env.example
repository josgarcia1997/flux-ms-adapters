PORT=3000
NODE_ENV=development

# Tenant fijo para todas las peticiones (UUID del tenant en tenant.tenants)
TENANT_ID=

# JWT (access token)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m

# OAuth (tablas oauth_access_tokens / oauth_refresh_tokens)
OAUTH_CLIENT_ID=1

# Base de datos (PostgreSQL) — la misma que usa Laravel
# Ejecución local (pnpm start): DB_HOST=localhost, DB_PORT=puerto de tu Postgres
# Docker (identity en contenedor, Laravel/Postgres en el host u otro contenedor):
#   DB_HOST=host.docker.internal  DB_PORT=puerto donde Laravel expone Postgres (ej. 5433)
DB_HOST=localhost
DB_PORT=5433
DB_DATABASE=flux
DB_USERNAME=flux
DB_PASSWORD=flux
DB_LOGGING=false
